    {
      "id": "fix-mime-type",
      "name": "Fix MIME Type",
      "parameters": {
        "jsCode": "const items = $input.all();\nfor (const item of items) {\n  if (item.binary && item.binary.data) {\n    item.binary.data.mimeType = 'image/jpeg';\n    item.binary.data.fileExtension = 'jpg';\n  }\n}\nreturn items;"
      },
      "position": [
        900,
        1040
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
    {
      "id": "5fad48a9-e126-4913-9875-5d1f5e723c8d",
      "name": "Code in JavaScript1",
      "parameters": {
        "jsCode": "const rawInput = $input.first().json['0']?.content[0]?.text || \"\";\nconst match = rawInput.match(/\\{[\\s\\S]*\\}/);\nif (!match) {\n  return [{ json: { error: \"No se detecto JSON\", raw: rawInput.substring(0, 50) } }];\n}\nconst forceNumber = (val) => {\n  if (val === undefined || val === null || val === \"\") return 0;\n  let clean = String(val).replace(/[^0-9.,-]/g, '');\n  let parsed = parseFloat(clean.replace(',', '.'));\n  return isNaN(parsed) ? 0 : parsed;\n};\ntry {\n  let sanitized = match[0].replace(/\\\\n/g, \" \").replace(/\\s+/g, \" \").trim();\n  const data = JSON.parse(sanitized);\n  return [{\n    json: {\n      proveedor: data.emisor?.nombre || data.vendor || \"Desconocido\",\n      cif_emisor: data.emisor?.cif || data.cif || \"N/A\",\n      fecha: data.documento?.fecha || data.date || new Date().toISOString().split('T')[0],\n      numero_doc: data.documento?.numero || data.invoice_number || \"S/N\",\n      base_imponible: forceNumber(data.importes?.base_imponible || data.base_imponible),\n      iva_total: forceNumber(data.importes?.iva_total || data.iva),\n      total_final: forceNumber(data.importes?.total_final || data.total),\n      moneda: data.importes?.moneda || \"EUR\",\n      detalles: typeof(data.conceptos_detallados) === 'object' ? JSON.stringify(data.conceptos_detallados) : (data.conceptos_detallados || \"Sin detalle\"),\n      tabla_destino: String(data.documento?.tipo || \"GASTOS_VARIOS\").toUpperCase().trim(),\n      resumen_telegram: data.resumen_telegram || \"\"\n    }\n  }];\n} catch (e) {\n  return [{ json: { error: \"Error de parseo\", detalle: e.message } }];\n}"
      },
      "position": [
        1312,
        864
      ],
      "type": "n8n-nodes-base.code",
      "typeVersion": 2
    },
